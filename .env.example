# Copy this file to .env for local runs that need model provider credentials.
# Leave values blank for providers you do not use.

# Anthropic direct API
ANTHROPIC_API_KEY=

# OpenAI direct API
OPENAI_API_KEY=

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-10-21

# AWS Bedrock or gateway-backed Bedrock access
AWS_REGION=
AWS_DEFAULT_REGION=
AWS_BEDROCK_ENDPOINT=
AWS_BEARER_TOKEN=
AWS_BEARER_TOKEN_BEDROCK=

# Optional token for non-loopback Web UI internal routes.
AEC_BENCH_INTERNAL_TOKEN=
